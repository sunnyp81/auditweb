---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TOC from '../components/TOC.astro';
import CTABanner from '../components/CTABanner.astro';
import LeadForm from '../components/LeadForm.astro';
import SeedCard from '../components/SeedCard.astro';
import EmailSignup from '../components/EmailSignup.astro';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface TocItem {
  label: string;
  id: string;
}

interface ChildPage {
  title: string;
  href: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  breadcrumbs: BreadcrumbItem[];
  toc?: TocItem[];
  children?: ChildPage[];
  schema?: object;
  showLeadForm?: boolean;
  showCTA?: boolean;
  ctaVariant?: 'primary' | 'accent';
  publishDate?: string;
  updateDate?: string;
}

const {
  title,
  description,
  breadcrumbs,
  toc,
  children: childPages,
  schema,
  showLeadForm = false,
  showCTA = true,
  ctaVariant = 'primary',
  publishDate,
  updateDate,
} = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  author: { '@type': 'Organization', name: 'AuditWeb' },
  publisher: { '@type': 'Organization', name: 'AuditWeb', url: 'https://auditweb.site' },
  ...(publishDate && { datePublished: publishDate }),
  ...(updateDate && { dateModified: updateDate }),
};

const mergedSchema = schema || articleSchema;
---

<BaseLayout title={title} description={description} schema={mergedSchema}>
  <Breadcrumbs items={breadcrumbs} />

  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <!-- Main Content -->
      <div class="lg:col-span-8">
        <header class="mb-10">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4">{title}</h1>
          <p class="text-lg text-text-muted">{description}</p>
          {(publishDate || updateDate) && (
            <div class="mt-4 text-sm text-text-dim">
              {updateDate ? `Updated ${updateDate}` : `Published ${publishDate}`}
            </div>
          )}
        </header>

        {toc && toc.length > 0 && <TOC items={toc} />}

        <div class="prose">
          <slot />
        </div>

        {showCTA && (
          <CTABanner variant={ctaVariant} />
        )}

        {childPages && childPages.length > 0 && (
          <section class="mt-12">
            <h2 class="text-2xl font-bold mb-6">Continue Reading</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {childPages.map(page => (
                <SeedCard title={page.title} href={page.href} description={page.description} />
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="sticky top-20 space-y-6">
          {showLeadForm ? (
            <LeadForm />
          ) : (
            <div class="glass rounded-2xl p-6">
              <h3 class="font-bold mb-3">Free Website Audit</h3>
              <p class="text-sm text-text-muted mb-4">Get an instant analysis of your website's health with our free 72-checkpoint scanner.</p>
              <a href="/free-website-audit/" class="block text-center px-4 py-2.5 bg-primary hover:bg-primary-dark text-surface font-semibold text-sm rounded-lg transition-colors">
                Run Free Audit
              </a>
            </div>
          )}

          <div class="glass rounded-2xl p-6">
            <h3 class="font-bold mb-3">Audit Types</h3>
            <ul class="space-y-2">
              <li><a href="/seo-website-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">SEO Audit</a></li>
              <li><a href="/technical-website-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">Technical Audit</a></li>
              <li><a href="/website-content-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">Content Audit</a></li>
              <li><a href="/website-security-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">Security Audit</a></li>
              <li><a href="/website-accessibility-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">Accessibility Audit</a></li>
            </ul>
          </div>

          <div class="glass rounded-2xl p-6">
            <h3 class="font-bold mb-3">Resources</h3>
            <ul class="space-y-2">
              <li><a href="/website-audit-checklist/" class="text-sm text-text-muted hover:text-primary transition-colors">Audit Checklists</a></li>
              <li><a href="/website-audit-tools/" class="text-sm text-text-muted hover:text-primary transition-colors">Best Audit Tools</a></li>
              <li><a href="/what-is-a-website-audit/" class="text-sm text-text-muted hover:text-primary transition-colors">What Is a Website Audit?</a></li>
            </ul>
          </div>

          <div class="glass rounded-2xl p-6">
            <h3 class="font-bold mb-3">Free SEO Tips</h3>
            <p class="text-sm text-text-muted mb-4">Weekly audit insights and optimisation strategies.</p>
            <EmailSignup source="sidebar" heading="" description="" submitText="Subscribe" />
          </div>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
