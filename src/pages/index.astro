---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AuditWeb',
  url: 'https://auditweb.site',
  description: 'Professional website audits that find what\'s broken and show you exactly how to fix it.',
};

const industries = [
  { icon: '🛒', name: 'E-commerce', desc: 'Stores & marketplaces' },
  { icon: '💻', name: 'SaaS', desc: 'Software platforms' },
  { icon: '📈', name: 'Lead Gen', desc: 'Service businesses' },
  { icon: '🏥', name: 'Healthcare', desc: 'Clinics & practices' },
  { icon: '⚖️', name: 'Legal', desc: 'Law firms' },
  { icon: '🏠', name: 'Real Estate', desc: 'Agencies & portals' },
  { icon: '🎓', name: 'Education', desc: 'Schools & courses' },
  { icon: '🏦', name: 'Finance', desc: 'Banks & fintech' },
  { icon: '🔧', name: 'Trades', desc: 'Local services' },
];

const commonIssues = [
  { title: 'Slow Page Speed', desc: '47% of users expect pages to load in under 2 seconds. Slow sites lose $4 per visitor in wasted ad spend.', fix: 'Image compression, code minification, CDN setup' },
  { title: 'Broken Internal Links', desc: 'Broken links waste crawl budget and create dead ends for users, hurting both SEO and conversions.', fix: 'Link audit, redirect mapping, 404 monitoring' },
  { title: 'Missing Meta Tags', desc: 'Pages without optimised title tags and descriptions get 36% fewer clicks from search results.', fix: 'Title tag templates, description optimisation, schema markup' },
  { title: 'Mobile Usability Issues', desc: '74% of mobile users abandon sites that aren\'t mobile-friendly. Google uses mobile-first indexing.', fix: 'Responsive design fixes, tap target sizing, viewport config' },
  { title: 'Thin Content', desc: 'Pages with insufficient content signal low quality to search engines, dragging down your entire site.', fix: 'Content gap analysis, page consolidation, topical depth' },
  { title: 'Security Vulnerabilities', desc: 'Missing SSL, outdated plugins, and exposed admin panels put your data and rankings at risk.', fix: 'SSL enforcement, security headers, vulnerability scan' },
];

const steps = [
  { num: '01', title: 'Submit Your URL', desc: 'Enter your website URL and we\'ll begin our 72-checkpoint analysis immediately.' },
  { num: '02', title: 'We Audit Everything', desc: 'Our team examines technical SEO, content quality, UX, security, speed, and competitive positioning.' },
  { num: '03', title: 'Get Your Action Plan', desc: 'Receive a prioritised report showing exactly what to fix, in what order, with expected ROI for each fix.' },
];

const pricing = [
  {
    name: 'Basic Audit',
    price: '$297',
    desc: 'Essential checks for small sites',
    features: ['Technical SEO scan', 'Page speed analysis', 'Mobile usability check', 'Meta tag audit', 'Top 10 priority fixes', 'PDF report'],
    cta: 'Get Basic Audit',
    popular: false,
  },
  {
    name: 'Comprehensive Audit',
    price: '$997',
    desc: 'Full 72-checkpoint deep dive',
    features: ['Everything in Basic', 'Content quality analysis', 'Competitor benchmarking', 'Backlink profile review', 'UX & conversion audit', 'Security vulnerability scan', 'Schema markup review', 'Prioritised action plan', '30-min strategy call'],
    cta: 'Get Comprehensive Audit',
    popular: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    desc: 'For large or complex sites',
    features: ['Everything in Comprehensive', 'Multi-site auditing', 'Custom KPI tracking', 'Ongoing monitoring', 'Dedicated account manager', 'Quarterly re-audits'],
    cta: 'Contact Us',
    popular: false,
  },
];

const testimonials = [
  { quote: 'The audit revealed issues we\'d been blind to for years. Within 3 months of implementing the fixes, our organic traffic increased 127%.', name: 'Sarah Chen', role: 'Marketing Director, TechFlow', metric: '127% traffic increase' },
  { quote: 'Worth every penny. The prioritised action plan meant we knew exactly what to fix first for maximum impact.', name: 'James Wright', role: 'Founder, Wright Legal', metric: '$43K revenue recovered' },
  { quote: 'We\'d spent thousands on ads without realising our site was leaking conversions. The audit paid for itself in the first week.', name: 'Priya Patel', role: 'E-commerce Manager, StyleHaus', metric: '3.2x ROI in 30 days' },
];
---

<BaseLayout
  title="AuditWeb — Professional Website Audits That Drive Results"
  description="Stop guessing what's wrong with your website. Our 72-checkpoint audit reveals exactly what's broken and shows you how to fix it. Free instant audit available."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 sm:pt-28 sm:pb-24">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/5 text-primary text-sm mb-6">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Trusted by 600+ businesses
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
          Stop Guessing What's Wrong
          <span class="gradient-text"> With Your Website</span>
        </h1>
        <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto mb-8">
          Our 72-checkpoint audit reveals exactly what's broken, what's costing you money, and how to fix it — in priority order.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
          <a href="/free-website-audit/" class="px-8 py-4 bg-primary hover:bg-primary-dark text-surface font-bold text-lg rounded-xl transition-colors animate-pulse-glow">
            Get Your Free Audit
          </a>
          <a href="/website-audit-services/" class="px-8 py-4 border border-border hover:border-primary/50 text-text font-semibold text-lg rounded-xl transition-colors">
            View Pricing
          </a>
        </div>
        <div class="flex flex-wrap justify-center gap-8 text-sm text-text-muted">
          <div class="flex items-center gap-2">
            <span class="text-warning font-bold text-lg">5.8/10</span>
            <span>Avg. site health score</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-danger font-bold text-lg">12%</span>
            <span>CVR impact from issues</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-success font-bold text-lg">24/7</span>
            <span>Monitoring available</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem / Opportunity -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Your Website Is Losing Money <span class="gradient-text">Right Now</span></h2>
      <p class="text-text-muted max-w-2xl mx-auto">Most websites have critical issues that silently drain traffic, conversions, and revenue. Here's what we typically find:</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="glass rounded-2xl p-6">
        <h3 class="font-semibold text-danger mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-danger"></span>
          Without an Audit
        </h3>
        <ul class="space-y-3 text-text-muted">
          <li class="flex items-start gap-2"><span class="text-danger mt-1">✕</span> Hidden technical issues tank your rankings</li>
          <li class="flex items-start gap-2"><span class="text-danger mt-1">✕</span> $4 wasted per visitor on ads to a broken site</li>
          <li class="flex items-start gap-2"><span class="text-danger mt-1">✕</span> 74% of mobile users bounce from unfriendly sites</li>
          <li class="flex items-start gap-2"><span class="text-danger mt-1">✕</span> Competitors outrank you with better site health</li>
        </ul>
      </div>
      <div class="glass rounded-2xl p-6 border-primary/20">
        <h3 class="font-semibold text-success mb-4 flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-success"></span>
          With an AuditWeb Report
        </h3>
        <ul class="space-y-3 text-text-muted">
          <li class="flex items-start gap-2"><span class="text-success mt-1">✓</span> Every issue found, categorised, and prioritised</li>
          <li class="flex items-start gap-2"><span class="text-success mt-1">✓</span> Clear ROI estimate for each fix</li>
          <li class="flex items-start gap-2"><span class="text-success mt-1">✓</span> Actionable steps your team can implement today</li>
          <li class="flex items-start gap-2"><span class="text-success mt-1">✓</span> Competitive edge with data-driven improvements</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">How It <span class="gradient-text">Works</span></h2>
      <p class="text-text-muted">Three simple steps to a healthier, higher-performing website.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map(step => (
        <div class="glass rounded-2xl p-6 text-center">
          <div class="text-4xl font-extrabold gradient-text mb-4">{step.num}</div>
          <h3 class="text-xl font-bold mb-2">{step.title}</h3>
          <p class="text-text-muted">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Common Issues -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Common Issues <span class="gradient-text">We Find</span></h2>
      <p class="text-text-muted max-w-2xl mx-auto">These are the top problems we discover across 600+ audits — most site owners don't know they exist.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {commonIssues.map(issue => (
        <div class="glass rounded-2xl p-6">
          <h3 class="font-bold text-lg mb-2">{issue.title}</h3>
          <p class="text-sm text-text-muted mb-3">{issue.desc}</p>
          <div class="text-xs text-primary font-medium">Fix: {issue.fix}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Industries -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Industries <span class="gradient-text">We Serve</span></h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {industries.map(ind => (
        <div class="glass rounded-xl p-4 text-center hover:border-primary/30 transition-all">
          <div class="text-2xl mb-2">{ind.icon}</div>
          <div class="font-semibold text-sm">{ind.name}</div>
          <div class="text-xs text-text-dim">{ind.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ROI Calculator -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Calculate Your <span class="gradient-text">Audit ROI</span></h2>
      <p class="text-text-muted">See how much revenue a website audit could unlock for your business.</p>
    </div>
    <div class="max-w-xl mx-auto glass rounded-2xl p-8">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Monthly Visitors</label>
          <input type="number" id="calc-visitors" value="10000" min="0"
            class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text focus:outline-none focus:border-primary transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Current Conversion Rate (%)</label>
          <input type="number" id="calc-cvr" value="2" min="0" max="100" step="0.1"
            class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text focus:outline-none focus:border-primary transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-2">Average Order Value ($)</label>
          <input type="number" id="calc-aov" value="50" min="0"
            class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text focus:outline-none focus:border-primary transition-colors" />
        </div>
        <div class="pt-4 border-t border-border">
          <div class="text-center">
            <p class="text-sm text-text-dim mb-1">Potential Monthly Revenue Increase</p>
            <p id="calc-result" class="text-4xl font-extrabold gradient-text">$3,000</p>
            <p class="text-xs text-text-dim mt-2">Based on a conservative 30% improvement in conversion rate from fixing audit issues</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function calcROI() {
      var visitors = parseFloat(document.getElementById('calc-visitors').value || '0');
      var cvr = parseFloat(document.getElementById('calc-cvr').value || '0') / 100;
      var aov = parseFloat(document.getElementById('calc-aov').value || '0');
      var increase = visitors * cvr * aov * 0.3;
      document.getElementById('calc-result').textContent = '$' + Math.round(increase).toLocaleString();
    }
    document.getElementById('calc-visitors').addEventListener('input', calcROI);
    document.getElementById('calc-cvr').addEventListener('input', calcROI);
    document.getElementById('calc-aov').addEventListener('input', calcROI);
  </script>

  <!-- Testimonials -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Trusted by <span class="gradient-text">Growing Businesses</span></h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="glass rounded-2xl p-6">
          <div class="text-primary text-sm font-semibold mb-3">{t.metric}</div>
          <p class="text-text-muted text-sm mb-4 italic">"{t.quote}"</p>
          <div>
            <div class="font-semibold text-sm">{t.name}</div>
            <div class="text-xs text-text-dim">{t.role}</div>
          </div>
        </div>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-10 mt-12 text-center">
      <div>
        <div class="text-3xl font-extrabold gradient-text">600+</div>
        <div class="text-sm text-text-dim">Audits Delivered</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold gradient-text">127%</div>
        <div class="text-sm text-text-dim">Avg. Traffic Increase</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold gradient-text">$2.3M</div>
        <div class="text-sm text-text-dim">Revenue Unlocked</div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Simple, Transparent <span class="gradient-text">Pricing</span></h2>
      <p class="text-text-muted">Choose the audit depth that matches your needs. 100% money-back guarantee.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {pricing.map(plan => (
        <div class={`glass rounded-2xl p-6 flex flex-col ${plan.popular ? 'border-primary/40 ring-1 ring-primary/20' : ''}`}>
          {plan.popular && (
            <div class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">Most Popular</div>
          )}
          <h3 class="text-xl font-bold mb-1">{plan.name}</h3>
          <p class="text-sm text-text-dim mb-4">{plan.desc}</p>
          <div class="text-3xl font-extrabold mb-6">{plan.price}</div>
          <ul class="space-y-2 mb-8 flex-1">
            {plan.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <span class="text-primary mt-0.5">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/website-audit-services/"
            class={`block text-center px-6 py-3 font-semibold rounded-lg transition-colors ${plan.popular ? 'bg-primary hover:bg-primary-dark text-surface glow-primary' : 'border border-border hover:border-primary/50 text-text'}`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <div class="inline-flex items-center gap-2 glass rounded-full px-5 py-2 text-sm text-text-muted">
        <span class="text-success">🛡️</span>
        100% Money-Back Guarantee — if we don't find at least $10,000 in potential revenue improvements
      </div>
    </div>
  </section>

  <!-- Email Signup -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="glass rounded-2xl p-10 sm:p-12 text-center">
      <h2 class="text-3xl font-bold mb-3">Free SEO Tips <span class="gradient-text">Every Week</span></h2>
      <p class="text-text-muted max-w-xl mx-auto mb-6">
        Get actionable website audit insights, SEO strategies, and optimisation tips from our team. Join 2,000+ marketers already subscribed.
      </p>
      <EmailSignup source="homepage" />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="rounded-2xl bg-gradient-to-r from-primary/10 to-accent/10 border border-primary/20 p-10 sm:p-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Ready to Fix Your Website?</h2>
      <p class="text-text-muted max-w-2xl mx-auto mb-8">
        Join 600+ businesses that have used our audits to increase traffic, improve conversions, and unlock hidden revenue.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-website-audit/" class="px-8 py-4 bg-primary hover:bg-primary-dark text-surface font-bold text-lg rounded-xl transition-colors glow-primary">
          Get Your Free Audit
        </a>
        <a href="/website-audit/" class="px-8 py-4 border border-border hover:border-primary/50 text-text font-semibold text-lg rounded-xl transition-colors">
          Read Our Audit Guide
        </a>
      </div>
      <p class="mt-4 text-sm text-text-dim">No credit card required &bull; Results in 60 seconds &bull; 100% confidential</p>
    </div>
  </section>
</BaseLayout>
