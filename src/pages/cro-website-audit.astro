const toc = [
  { label: 'What Is a CRO Audit', id: 'what-is' },
  { label: 'CRO vs UX Audit', id: 'vs-ux' },
  { label: 'Analytics Deep Dive', id: 'analytics' },
  { label: 'Landing Page Analysis', id: 'landing-pages' },
