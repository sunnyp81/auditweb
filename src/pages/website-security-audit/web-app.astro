<ContentLayout
  title="Web Application Security Audit: OWASP Top 10 Guide"
  description="Learn how to audit web application security against the OWASP Top 10. Covers injection attacks, broken authentication, XSS, security misconfiguration, and a complete testing methodology."
  breadcrumbs={breadcrumbs}
