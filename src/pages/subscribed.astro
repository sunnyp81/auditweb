---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're Subscribed — AuditWeb"
  description="Thanks for subscribing to AuditWeb. You'll receive weekly SEO tips and website audit insights."
  noindex={true}
>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="glass rounded-2xl p-10">
      <div class="text-5xl mb-6">✓</div>
      <h1 class="text-3xl font-extrabold mb-4">You're In!</h1>
      <p class="text-text-muted mb-6">
        Thanks for subscribing. You'll get weekly SEO tips, audit insights, and website optimisation strategies straight to your inbox.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/website-audit/" class="px-6 py-3 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors">
          Read Our Audit Guide
        </a>
        <a href="/free-website-audit/" class="px-6 py-3 border border-border hover:border-primary/50 text-text font-semibold rounded-lg transition-colors">
          Try the Free Scanner
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
