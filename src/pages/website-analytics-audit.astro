import ContentLayout from '../layouts/ContentLayout.astro';

const toc = [
  { label: 'What Is an Analytics Audit', id: 'what-is' },
  { label: 'GA4 Configuration Check', id: 'ga4' },
  { label: 'Tracking Accuracy', id: 'accuracy' },
  { label: 'Goal and Conversion Setup', id: 'conversions' },
  { label: 'Event Tracking Review', id: 'events' },
