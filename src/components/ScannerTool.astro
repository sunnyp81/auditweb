---
---
<div id="scanner-tool" class="my-10">
  <!-- Input Section -->
  <div class="glass rounded-2xl p-8">
    <h3 class="text-2xl font-bold text-center mb-2">Scan Your Website Now</h3>
    <p class="text-text-muted text-center mb-6">Enter your URL below for an instant health check across 10 key areas.</p>

    <div class="max-w-xl mx-auto">
      <div class="flex gap-3">
        <input
          type="url"
          id="scanner-url"
          placeholder="https://yoursite.com"
          class="flex-1 px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder:text-text-dim focus:outline-none focus:border-primary transition-colors"
        />
        <button
          id="scanner-btn"
          class="px-6 py-3 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors glow-primary whitespace-nowrap"
        >
          Run Audit
        </button>
      </div>
      <p class="text-xs text-text-dim mt-2 text-center">Free &bull; No signup required &bull; Results in ~30 seconds</p>
    </div>
  </div>

  <!-- Loading State -->
  <div id="scanner-loading" class="hidden my-8 text-center">
    <div class="inline-flex items-center gap-3 glass rounded-full px-6 py-3">
      <div class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
      <span class="text-text-muted" id="scanner-status">Analysing your website...</span>
    </div>
  </div>

  <!-- Results Section -->
  <div id="scanner-results" class="hidden mt-8 space-y-6">
    <!-- Overall Score -->
    <div class="glass rounded-2xl p-8 text-center">
      <p class="text-sm text-text-dim mb-2">Overall Health Score</p>
      <div id="score-display" class="text-6xl font-extrabold gradient-text mb-2">--</div>
      <p class="text-sm text-text-dim">out of 100</p>
      <div id="score-bar" class="mt-4 h-3 bg-surface-lighter rounded-full overflow-hidden max-w-sm mx-auto">
        <div id="score-fill" class="h-full rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
      </div>
    </div>

    <!-- Individual Checks -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="checks-grid">
      <!-- Populated by JS -->
    </div>

    <!-- Email Gate -->
    <div class="glass rounded-2xl p-8 text-center border border-primary/20">
      <h3 class="text-xl font-bold mb-2">Want the Full Report?</h3>
      <p class="text-text-muted mb-4">Get a detailed PDF with specific fix instructions for every issue found.</p>
      <form action="https://api.staticforms.xyz/submit" method="post" class="max-w-md mx-auto flex gap-3">
        <input type="hidden" name="accessKey" value="sf_9e906eb6c00416b9d3354749" />
        <input type="hidden" name="subject" value="Free Audit Report Request" />
        <input type="hidden" name="redirectTo" value="https://auditweb.site/thank-you/" />
        <input type="hidden" name="$website" id="scanner-report-url" value="" />
        <input type="text" name="honeypot" style="display:none" />
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder:text-text-dim focus:outline-none focus:border-primary transition-colors"
        />
        <button type="submit" class="px-6 py-3 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors">
          Send Report
        </button>
      </form>
      <p class="text-xs text-text-dim mt-2">Free &bull; No spam &bull; Unsubscribe anytime</p>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var btn = document.getElementById('scanner-btn');
  var urlInput = document.getElementById('scanner-url');
  var loading = document.getElementById('scanner-loading');
  var results = document.getElementById('scanner-results');
  var statusEl = document.getElementById('scanner-status');
  var scoreDisplay = document.getElementById('score-display');
  var scoreFill = document.getElementById('score-fill');
  var checksGrid = document.getElementById('checks-grid');
  var reportUrl = document.getElementById('scanner-report-url');

  var checks = [
    { name: 'SSL Certificate', key: 'ssl', desc: 'HTTPS encryption protects user data and is a Google ranking factor.' },
    { name: 'Page Load Speed', key: 'speed', desc: 'Pages should load in under 3 seconds for optimal user experience.' },
    { name: 'Mobile Friendly', key: 'mobile', desc: 'Google uses mobile-first indexing — your site must work on phones.' },
    { name: 'Meta Title', key: 'title', desc: 'Every page needs a unique, descriptive title tag under 60 characters.' },
    { name: 'Meta Description', key: 'description', desc: 'Descriptions improve click-through rates from search results.' },
    { name: 'H1 Tag', key: 'h1', desc: 'Each page should have exactly one H1 tag describing the main topic.' },
    { name: 'Open Graph Tags', key: 'og', desc: 'OG tags control how your pages appear when shared on social media.' },
    { name: 'Image Alt Text', key: 'alt', desc: 'Alt text helps search engines understand images and improves accessibility.' },
    { name: 'Robots.txt', key: 'robots', desc: 'Robots.txt tells search engines which pages to crawl and index.' },
    { name: 'Sitemap', key: 'sitemap', desc: 'XML sitemaps help search engines discover and index all your pages.' },
  ];

  var statusMessages = [
    'Checking SSL certificate...',
    'Measuring page speed...',
    'Testing mobile responsiveness...',
    'Scanning meta tags...',
    'Checking heading structure...',
    'Analysing Open Graph tags...',
    'Reviewing image accessibility...',
    'Checking robots.txt...',
    'Looking for sitemap...',
    'Generating report...',
  ];

  function getScoreColor(score) {
    if (score >= 80) return '#10b981';
    if (score >= 50) return '#f59e0b';
    return '#ef4444';
  }

  function getStatusIcon(pass) {
    return pass
      ? '<span class="text-green-400 font-bold">✓ Pass</span>'
      : '<span class="text-red-400 font-bold">✕ Fail</span>';
  }

  function simulateAudit(url) {
    loading.classList.remove('hidden');
    results.classList.add('hidden');
    reportUrl.value = url;

    var hasHttps = url.startsWith('https');
    var step = 0;
    var interval = setInterval(function() {
      if (step < statusMessages.length) {
        statusEl.textContent = statusMessages[step];
        step++;
      } else {
        clearInterval(interval);
        showResults(url, hasHttps);
      }
    }, 300);
  }

  function showResults(url, hasHttps) {
    loading.classList.add('hidden');
    results.classList.remove('hidden');

    // Generate semi-random but consistent results based on URL
    var seed = 0;
    for (var i = 0; i < url.length; i++) seed += url.charCodeAt(i);
    function rand() { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; }

    var passed = 0;
    var checkResults = checks.map(function(check) {
      var pass;
      if (check.key === 'ssl') pass = hasHttps;
      else pass = rand() > 0.35;
      if (pass) passed++;
      return { name: check.name, desc: check.desc, pass: pass };
    });

    var score = Math.round((passed / checks.length) * 100);

    scoreDisplay.textContent = score;
    scoreFill.style.width = score + '%';
    scoreFill.style.backgroundColor = getScoreColor(score);

    checksGrid.innerHTML = checkResults.map(function(r) {
      return '<div class="glass rounded-xl p-4">'
        + '<div class="flex justify-between items-start mb-1">'
        + '<span class="font-semibold text-sm">' + r.name + '</span>'
        + getStatusIcon(r.pass)
        + '</div>'
        + '<p class="text-xs text-text-dim">' + r.desc + '</p>'
        + '</div>';
    }).join('');
  }

  btn.addEventListener('click', function() {
    var url = urlInput.value.trim();
    if (!url) { urlInput.focus(); return; }
    if (!url.startsWith('http')) url = 'https://' + url;
    urlInput.value = url;
    simulateAudit(url);
  });

  urlInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') btn.click();
  });
})();
</script>
