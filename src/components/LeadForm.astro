---
interface Props {
  formId?: string;
  heading?: string;
  submitText?: string;
}

const {
  formId = 'lead-form',
  heading = 'Request Your Professional Audit',
  submitText = 'Get My Audit',
} = Astro.props;
---

<div class="glass rounded-2xl p-6 sm:p-8">
  <h3 class="text-xl font-bold mb-4">{heading}</h3>
  <form
    id={formId}
    action="https://api.staticforms.xyz/submit"
    method="post"
    class="space-y-4"
  >
  <input type="hidden" name="_site" value="auditweb.site" />
    <input type="hidden" name="accessKey" value="sf_9e906eb6c00416b9d3354749" />
    <input type="hidden" name="subject" value="Enquiry from auditweb.site" />
    <input type="hidden" name="redirectTo" value="https://auditweb.site/thank-you/" />
    <input type="text" name="honeypot" style="display:none" />

    <div>
      <label for={`${formId}-name`} class="block text-sm font-medium text-text-muted mb-1">Name</label>
      <input
        type="text"
        id={`${formId}-name`}
        name="name"
        required
        class="w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-text placeholder:text-text-dim focus:outline-none focus:border-primary transition-colors"
        placeholder="Your name"
      />
    </div>

    <div>
      <label for={`${formId}-email`} class="block text-sm font-medium text-text-muted mb-1">Email</label>
      <input
        type="email"
        id={`${formId}-email`}
        name="email"
        required
        class="w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-text placeholder:text-text-dim focus:outline-none focus:border-primary transition-colors"
        placeholder="you@company.com"
      />
    </div>

    <div>
      <label for={`${formId}-url`} class="block text-sm font-medium text-text-muted mb-1">Website URL</label>
      <input
        type="url"
        id={`${formId}-url`}
        name="$website"
        required
        class="w-full px-4 py-2.5 bg-surface border border-border rounded-lg text-text placeholder:text-text-dim focus:outline-none focus:border-primary transition-colors"
        placeholder="https://yoursite.com"
      />
    </div>

    <button
      type="submit"
      class="w-full px-6 py-3 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors glow-primary"
    >
      {submitText}
    </button>

    <p class="text-xs text-text-dim text-center">100% confidential &bull; No spam, ever</p>
  </form>
</div>
