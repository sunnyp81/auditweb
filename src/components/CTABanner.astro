---
interface Props {
  headline?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  variant?: 'primary' | 'accent';
}

const {
  headline = 'Get Your Free Website Audit',
  description = 'Find out what\'s holding your website back. Our 72-checkpoint audit reveals exactly what to fix.',
  buttonText = 'Start Free Audit',
  buttonHref = '/free-website-audit/',
  variant = 'primary',
} = Astro.props;

const gradientClass = variant === 'accent'
  ? 'from-accent/10 to-primary/10 border-accent/20'
  : 'from-primary/10 to-accent/10 border-primary/20';
---

<section class={`my-12 rounded-2xl bg-gradient-to-r ${gradientClass} border p-8 sm:p-10 text-center`}>
  <h3 class="text-2xl font-bold mb-3">{headline}</h3>
  <p class="text-text-muted max-w-2xl mx-auto mb-6">{description}</p>
  <a href={buttonHref} class="inline-flex px-6 py-3 bg-primary hover:bg-primary-dark text-surface font-semibold rounded-lg transition-colors glow-primary">
    {buttonText}
  </a>
  <p class="mt-3 text-xs text-text-dim">No credit card required &bull; Results in 60 seconds</p>
</section>
